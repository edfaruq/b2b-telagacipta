DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=b2b_telagacipta
# Max connections per app pool (default 5). Lower if MySQL reports "Too many connections".
DB_CONNECTION_LIMIT=5

# PayPal Sandbox (server secret never exposed to browser)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# USD works on most Sandbox accounts; use IDR only if your merchant supports it
PAYPAL_CURRENCY=USD
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
# 1 USD = PAYPAL_IDR_PER_USD IDR (sandbox conversion when PAYPAL_CURRENCY=USD)
PAYPAL_IDR_PER_USD=16000

# Footer social links (optional — defaults in src/lib/site-social.ts)
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/in/edfaruq/
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/alfaruq_
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/telagaciptaindonesia/
# NEXT_PUBLIC_SOCIAL_WHATSAPP=https://wa.me/6281234567890
