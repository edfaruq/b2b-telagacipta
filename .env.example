DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=b2b_telagacipta
# Max connections per app pool (default 5). Lower if MySQL reports "Too many connections".
DB_CONNECTION_LIMIT=5

# PayPal Sandbox (server secret never exposed to browser)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# USD works on most Sandbox accounts; use IDR only if your merchant supports it
PAYPAL_CURRENCY=USD
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
# 1 USD = PAYPAL_IDR_PER_USD IDR (sandbox conversion when PAYPAL_CURRENCY=USD)
PAYPAL_IDR_PER_USD=16000

# Shipping: mock (default, no API) | biteship (live API + BITESHIP_API_KEY)
SHIPPING_PROVIDER=mock

# Biteship (server only — never expose BITESHIP_API_KEY to the browser)
# Required only when SHIPPING_PROVIDER=biteship
BITESHIP_API_KEY=
# BITESHIP_API_BASE_URL=https://api.biteship.com
BITESHIP_ORIGIN_CONTACT_NAME=PT Telaga Cipta Indonesia
BITESHIP_ORIGIN_CONTACT_PHONE=02112345678
BITESHIP_ORIGIN_CONTACT_EMAIL=export@telagacipta.com
BITESHIP_ORIGIN_ADDRESS=Graha Surveyor Indonesia, Jl. Gatot Subroto No.Kav. 56, Jakarta Selatan, DKI Jakarta 12950
BITESHIP_ORIGIN_POSTAL_CODE=12950
BITESHIP_DEFAULT_DESTINATION_POSTAL_CODE=12950
BITESHIP_DEFAULT_ITEM_WEIGHT_GRAMS=1000
BITESHIP_DEFAULT_COURIERS=jne,sicepat,anteraja,jnt,pos,tiki,wahana
